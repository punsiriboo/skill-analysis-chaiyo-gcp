# คัดลอกเป็น env.yaml แล้วใส่ค่า GEMINI_API_KEY จริง
# Cloud Run จะอ่าน env จากไฟล์นี้ตอน deploy (ใช้ใน deploy.sh)
#
# ตัวเลือกที่ 1: ใส่ key โดยตรง
# GEMINI_API_KEY: "AIzaSy..."
#
# ตัวเลือกที่ 2: ใช้ Secret Manager (แนะนำสำหรับ production)
# GEMINI_API_KEY: "projects/YOUR_PROJECT_ID/secrets/gemini-api-key/versions/latest"
GEMINI_API_KEY: "YOUR_GEMINI_API_KEY"
